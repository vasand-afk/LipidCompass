{
  "expo": {
    "name": "LipidCompass",
    "slug": "lipidiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "lipidiq",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.VasanHealth.LipidCompass",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F4C75",
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "package": "com.vasanhealth.lipidcompass",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0F4C75"
        }
      ]
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e0cc82e8-df46-4e22-8f10-e0a0f50fd1e4"
      }
    }
  }
}
